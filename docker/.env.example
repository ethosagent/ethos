# Azure OpenAI credentials
# Copy this file to .env and fill in your real values.
# The .env file is gitignored — never commit it.

# Where ethos stores its data on YOUR machine (config, secrets, sessions, logs).
# Can be an absolute path or relative to the docker/ folder.
# Default: ../ethos-data  (the ethos-data/ folder at the repo root)
# Examples:
#   ETHOS_DATA_DIR=../ethos-data          # repo-relative (default)
#   ETHOS_DATA_DIR=/Users/you/ethos-data  # absolute path on Mac/Linux
#   ETHOS_DATA_DIR=C:\Users\you\ethos-data  # absolute path on Windows
ETHOS_DATA_DIR=../ethos-data

AZURE_API_KEY=your-azure-openai-api-key-here
AZURE_ENDPOINT=https://your-resource.openai.azure.com
AZURE_MODEL=gpt-4o
AZURE_API_VERSION=2024-12-01-preview

# OpenRouter credentials (alternative to Azure)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openai/gpt-4o
TELEGRAM_BOT_TOKEN=token_bot_token_here

# Your Telegram user ID (get it from @userinfobot on Telegram) — required when TELEGRAM_BOT_TOKEN is set
# TELEGRAM_OWNER_ID=123456789

# Personality to use (default: researcher). Run 'ethos personality list' to see all options.
# ETHOS_PERSONALITY=researcher
