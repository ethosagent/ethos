{
  "name": "@ethosagent/web-contracts",
  "version": "0.5.1",
  "type": "module",
  "description": "Typed oRPC contract and Zod schemas for the Ethos web API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ethosagent/ethos",
    "directory": "packages/web-contracts"
  },
  "keywords": [
    "ethos",
    "agent",
    "sdk",
    "contracts",
    "orpc",
    "zod"
  ],
  "files": [
    "dist",
    "src",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "production": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts"
  },
  "dependencies": {
    "@orpc/contract": "^1.14.3",
    "zod": "^4.3.6"
  }
}
