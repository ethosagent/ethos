{
  "name": "@ethosagent/sdk",
  "version": "0.3.8",
  "type": "module",
  "description": "TypeScript SDK for building Mission Control dashboards on Ethos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ethosagent/ethos",
    "directory": "packages/sdk"
  },
  "keywords": [
    "ethos",
    "agent",
    "sdk",
    "mission-control",
    "dashboard"
  ],
  "files": [
    "dist",
    "src",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "production": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts"
  },
  "dependencies": {
    "@ethosagent/web-contracts": "workspace:*",
    "@orpc/client": "^1.14.0",
    "@orpc/contract": "^1.14.0"
  }
}
