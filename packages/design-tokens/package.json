{
  "name": "@ethosagent/design-tokens",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "DESIGN.md tokens as a runtime package. Single source of truth for visual identity across all surfaces (TUI, Web, CLI, VS Code, email).",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "production": "./dist/index.js"
    },
    "./antd": {
      "import": "./src/antd.ts",
      "types": "./src/antd.ts",
      "production": "./dist/antd.js"
    },
    "./chalk": {
      "import": "./src/chalk.ts",
      "types": "./src/chalk.ts",
      "production": "./dist/chalk.js"
    },
    "./inline-css": {
      "import": "./src/inline-css.ts",
      "types": "./src/inline-css.ts",
      "production": "./dist/inline-css.js"
    },
    "./vscode": {
      "import": "./src/vscode.ts",
      "types": "./src/vscode.ts",
      "production": "./dist/vscode.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/antd.ts src/chalk.ts src/inline-css.ts src/vscode.ts --format esm --dts"
  },
  "peerDependencies": {
    "antd": "^5.21.0",
    "chalk": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "antd": {
      "optional": true
    },
    "chalk": {
      "optional": true
    }
  }
}
