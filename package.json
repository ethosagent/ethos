{
  "name": "ethos-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "prepare": "bash scripts/install-hooks.sh",
    "build": "pnpm -r --filter='./packages/*' --filter='./extensions/*' --filter='./apps/*' run build",
    "build:model-catalog": "tsx packages/wiring/scripts/build-model-catalog.ts",
    "build:web": "pnpm --filter @ethosagent/web build",
    "dev": "tsx apps/ethos/src/index.ts",
    "dev:web": "pnpm --filter @ethosagent/web dev",
    "test": "vitest run",
    "test:concurrent": "vitest run --pool=threads extensions/team-supervisor/src/__tests__/concurrent extensions/agent-mesh/src/__tests__/concurrent",
    "test:watch": "vitest",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json && pnpm --filter @ethosagent/web typecheck && pnpm --filter @ethosagent/desktop typecheck",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "find . -name 'dist' -not -path '*/node_modules/*' -exec rm -rf {} + 2>/dev/null; true",
    "docs": "pnpm --filter docs run start",
    "docs:build": "pnpm --filter docs run build",
    "docs:check": "pnpm --filter docs run check",
    "test:catalog-smoke": "bash scripts/smoke-test-catalog.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "pino": "^10.3.1",
    "playwright": "^1.59.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@discordjs/opus",
      "argon2",
      "electron",
      "esbuild",
      "playwright"
    ],
    "peerDependencyRules": {
      "ignoreMissing": [
        "zod"
      ]
    },
    "overrides": {
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0"
    },
    "ignoredBuiltDependencies": [
      "@swc/core",
      "keytar"
    ]
  }
}
