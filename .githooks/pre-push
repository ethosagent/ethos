#!/usr/bin/env bash
#
# Ethos pre-push hook — local safety net before content leaves the machine.
# Mirrors what CI runs, minus tests (CI handles those — keeps `git push`
# under ~10s when only code changes, ~60s when docs/ changed).
#
# Always runs:
#   - typecheck       (~5s)
#   - lint            (<1s)
#   - tool-imports    (<1s)
#   - version-sync    (<1s)
#
# Conditional (only when files under docs/ or docs/sidebars.ts changed):
#   - docs:check      (front-matter / kind / anchor / orphan gates)
#   - docs build      (broken-link + broken-anchor gate — the recurring CI red)
#
# Bypass:
#   git push --no-verify              skip every check (use only for real emergencies; CI still runs remotely)
#   SKIP_PUSH_HOOK=1 git push         identical to --no-verify, works where --no-verify isn't reachable
#   SKIP_DOCS_HOOK=1 git push         skip just the docs gates (useful for content-only edits you'll verify in CI)
#
# This hook is wired by `scripts/install-hooks.sh`, which is invoked by the
# root `prepare` script on `pnpm install`. New clones get it automatically.

set -euo pipefail

if [[ "${SKIP_PUSH_HOOK:-}" == "1" ]]; then
  echo "[pre-push] SKIP_PUSH_HOOK=1 — skipping all checks."
  exit 0
fi

# ---------------------------------------------------------------------------
# Determine whether docs/ changed in this push.
#
# pre-push receives <local_ref> <local_sha> <remote_ref> <remote_sha> on stdin,
# one line per ref being pushed. For each, diff the local commits against
# the remote tip (or the merge-base with origin/main when the remote ref is
# new, signalled by an all-zero remote_sha).
# ---------------------------------------------------------------------------

ZERO_SHA="0000000000000000000000000000000000000000"
DOCS_CHANGED=0

# Read stdin once. If no input (e.g. tooling invoked the hook without piping
# refs), fall back to comparing HEAD against origin/main.
if [[ ! -t 0 ]]; then
  while read -r local_ref local_sha remote_ref remote_sha; do
    if [[ "$local_sha" == "$ZERO_SHA" ]]; then
      # Local side deleted — nothing to scan.
      continue
    fi

    if [[ "$remote_sha" == "$ZERO_SHA" ]]; then
      # New remote branch — compare against the merge-base with origin/main
      # (best heuristic for "what new commits are we pushing?"). If
      # origin/main isn't reachable (fresh clone with no fetch), fall back
      # to the local commit's first parent — worst case we over-detect docs
      # changes and run the gates, which is the safe direction.
      base=$(git merge-base "$local_sha" origin/main 2>/dev/null || echo "")
      if [[ -z "$base" ]]; then
        base=$(git rev-list --max-parents=0 "$local_sha" | tail -1)
      fi
    else
      base="$remote_sha"
    fi

    if git diff --name-only "$base...$local_sha" -- docs/ 2>/dev/null | grep -q .; then
      DOCS_CHANGED=1
      break
    fi
  done
else
  # No stdin available — defensive fallback.
  if git diff --name-only "origin/main...HEAD" -- docs/ 2>/dev/null | grep -q .; then
    DOCS_CHANGED=1
  fi
fi

# ---------------------------------------------------------------------------
# Always-on gates.
# ---------------------------------------------------------------------------

run() {
  local label="$1"
  shift
  printf "[pre-push] %-15s" "$label"
  local start; start=$(date +%s)
  if "$@" > /tmp/ethos-prepush.log 2>&1; then
    local end; end=$(date +%s)
    printf "✓ (%ds)\n" $((end - start))
  else
    local end; end=$(date +%s)
    printf "✗ (%ds)\n\n" $((end - start))
    echo "------ $label output ------"
    cat /tmp/ethos-prepush.log
    echo "---------------------------"
    echo ""
    echo "Push rejected. Fix the issues above, then retry."
    echo "Bypass (emergency only): git push --no-verify"
    exit 1
  fi
}

run "typecheck"    bash scripts/check-typecheck.sh
run "lint"         bash scripts/check-lint.sh
run "tool-imports" bash scripts/check-tool-imports.sh
run "version-sync" bash scripts/check-version-sync.sh

# ---------------------------------------------------------------------------
# Conditional docs gates.
# ---------------------------------------------------------------------------

if [[ "$DOCS_CHANGED" == "1" ]]; then
  if [[ "${SKIP_DOCS_HOOK:-}" == "1" ]]; then
    echo "[pre-push] docs/ changed but SKIP_DOCS_HOOK=1 — skipping docs gates."
  else
    run "docs:check"   bash scripts/check-docs.sh
    run "docs build"   pnpm --filter docs run build
  fi
else
  echo "[pre-push] no docs/ changes — skipping docs gates."
fi

echo "[pre-push] ✓ All checks passed. Pushing..."
