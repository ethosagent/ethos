{
  "name": "@ethosagent/cli",
  "version": "0.4.21",
  "description": "Ethos — TypeScript AI agent framework where personality is architecture. Curated toolsets, first-person identities, scoped memory.",
  "keywords": [
    "agent",
    "ai",
    "llm",
    "claude",
    "openai",
    "personality",
    "framework",
    "cli",
    "anthropic"
  ],
  "homepage": "https://ethosagent.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ethosagent/ethos.git",
    "directory": "apps/ethos"
  },
  "bugs": "https://github.com/ethosagent/ethos/issues",
  "license": "MIT",
  "author": "Ethos contributors",
  "type": "module",
  "bin": {
    "ethos": "./dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "skills",
    "web",
    "templates",
    "scripts/postinstall.mjs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "scripts": {
    "copy-data": "rm -rf data && cp -R ../../extensions/personalities/data data",
    "copy-web": "pnpm --filter @ethosagent/web build && rm -rf web && cp -R ../web/dist web && find web -name '*.map' -delete",
    "copy-skills": "rm -rf skills && cp -R ../../skills skills",
    "prebuild": "pnpm copy-data && pnpm copy-web && pnpm copy-skills",
    "build": "tsup",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "@ethosagent/core": "workspace:*",
    "@ethosagent/types": "workspace:*",
    "@anthropic-ai/sdk": "^0.96.0",
    "@aws-sdk/client-secrets-manager": "^3.800.0",
    "@hono/node-server": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@orpc/contract": "^1.14.3",
    "@orpc/openapi": "^1.14.0",
    "@orpc/server": "^1.14.0",
    "argon2": "^0.43.0",
    "croner": "^9.0.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.15",
    "ink": "^7.0.0",
    "openai": "^6.37.0",
    "pino": "^10.3.1",
    "react": "19.2.6",
    "ws": "^8.20.0",
    "yaml": "^2.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ethosagent/agent-bridge": "workspace:*",
    "@ethosagent/agent-mesh": "workspace:*",
    "@ethosagent/cron": "workspace:*",
    "@ethosagent/digest": "workspace:*",
    "@ethosagent/gateway": "workspace:*",
    "@ethosagent/goal-runner": "workspace:*",
    "@ethosagent/goal-store": "workspace:*",
    "@ethosagent/kanban-store": "workspace:*",
    "@ethosagent/logger": "workspace:*",
    "@ethosagent/mcp-server": "workspace:*",
    "@ethosagent/nightly-loop": "workspace:*",
    "@ethosagent/observability-sqlite": "workspace:*",
    "@ethosagent/request-dump": "workspace:*",
    "@ethosagent/personalities": "workspace:*",
    "@ethosagent/personality-judge": "workspace:*",
    "@ethosagent/safety-channel": "workspace:*",
    "@ethosagent/safety-redact": "workspace:*",
    "@ethosagent/safety-scanner": "workspace:*",
    "@ethosagent/secrets-aws": "workspace:*",
    "@ethosagent/session-lane": "workspace:*",
    "@ethosagent/skills": "workspace:*",
    "@ethosagent/storage-fs": "workspace:*",
    "@ethosagent/session-sqlite": "workspace:*",
    "@ethosagent/sqlite": "workspace:*",
    "@ethosagent/team-supervisor": "workspace:*",
    "@ethosagent/tools-process": "workspace:*",
    "@ethosagent/web-api": "workspace:*",
    "@ethosagent/wiring": "workspace:*"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2",
    "@slack/bolt": "^3.21.0",
    "discord.js": "^14.16.0",
    "grammy": "^1.26.0",
    "imapflow": "^1.0.170",
    "mailparser": "^3.7.2",
    "nodemailer": "^6.10.1",
    "playwright": "^1.48.0"
  }
}
